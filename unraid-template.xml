<?xml version="1.0"?>
<Container version="2">
  <Name>fsm</Name>
  <Repository>s0ct/fsm</Repository>
  <Registry>https://hub.docker.com/r/s0ct/fsm/</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project/>
  <Overview>Factorio Server Manager run your Factorio server with ease&#xD;
&#xD;
https://hub.docker.com/r/S0CT/fsm/</Overview>
  <Category>Tools:</Category>
  <WebUI>http://[IP]:[PORT:8888]</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/S0CT/fsm/main/fsm-icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>Factorio Server Manager run your Factorio server with ease&#xD;
&#xD;
https://hub.docker.com/r/S0CT/fsm/</Description>
  <!-- Unraid Optimization: Pre-defined explicit mappings for Factorio Server Manager -->
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>8888</HostPort>
        <ContainerPort>8888</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
      <Port>
        <HostPort>27015</HostPort>
        <ContainerPort>27015</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
      <Port>
        <HostPort>34197</HostPort>
        <ContainerPort>34197</ContainerPort>
        <Protocol>udp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/fsm</HostDir>
      <ContainerDir>/data</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment/>
  <Labels/>
  <Config Name="Container Port 1" Target="8888" Default="8888" Mode="tcp" Description="Container Port: 8888" Type="Port" Display="always" Required="true" Mask="false">8888</Config>
  <Config Name="Appdata Directory" Target="/data" Default="/mnt/user/appdata/fsm" Mode="rw" Description="Container Path: /data" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/fsm</Config>
  <Config Name="RCON Port" Target="27015" Default="27015" Mode="tcp" Description="Container Port: 27015" Type="Port" Display="always" Required="true" Mask="false">27015</Config>
  <Config Name="Factorio Game Server Port" Target="34197" Default="34197" Mode="udp" Description="Container Port: 34197&#13;&#10;Game Server port" Type="Port" Display="always" Required="true" Mask="false">34197</Config>
  <Config Name="Factorio Username" Target="FACTORIO_USERNAME" Default="" Mode="" Description="Factorio account username for downloading servers." Type="Variable" Display="always" Required="false" Mask="false"></Config>
  <Config Name="Factorio Token" Target="FACTORIO_TOKEN" Default="" Mode="" Description="Factorio API token (get at factorio.com/profile). Required alongside Username." Type="Variable" Display="always" Required="false" Mask="true"></Config>
  <Config Name="PUID" Target="PUID" Default="99" Mode="" Description="Container Variable: PUID" Type="Variable" Display="advanced" Required="false" Mask="false">99</Config>
  <Config Name="PGID" Target="PGID" Default="100" Mode="" Description="Container Variable: PGID" Type="Variable" Display="advanced" Required="false" Mask="false">100</Config>
</Container>
